{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "ES2022",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "_build",
    "rootDir": ".",
    "allowJs": true,
    "pretty": true,
    "types": [
      "@girs/gjs/ambient",
      "@girs/adw-1/ambient",
      "@girs/gtk-4.0/ambient",
      "@girs/gio-2.0/ambient",
      "@girs/gobject-2.0/ambient",
      "@girs/glib-2.0/ambient"
    ]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", ".flatpak", "_build", "**/node_modules/*"]
}
