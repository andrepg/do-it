<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@APPLICATION_ID@</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>

  <name>Do It</name>
  <summary>Deadly simple to-do manager</summary>
  <description>
    <p>
      A simple task manager with basic functionality to handle
      one day at a time. Create, update, delete and finish tasks easily.
    </p>

    <p>
      Totally offline, telemetry-free and privacy-focused. No sync, nor tracking.
      Simple enough to just keep track of what need to be done.
    </p>

    <ul>
      <li>Create and delete as many tasks as you want</li>
      <li>Mark as finished or reopen any task, any time</li>
      <li>Delete tasks and do not worry - they will be purged when app closes</li>
      <li>Purge deleted tasks if you do not want to see that many tasks</li>
      <li>Sort your tasks by Title, Status or Creation Date, ascending or descending</li>
    </ul>

    <p>**This app is available only in English and Brazilian Portuguese for now.**</p>
  </description>

  <developer id="io.github.andrepg">
    <name>André Paul Grandsire</name>
  </developer>

  <categories>
    <category>Utility</category>
  </categories>

  <keywords>
    <keyword>todo</keyword>
    <keyword>work</keyword>
    <keyword>list</keyword>
    <keyword>productivity</keyword>
  </keywords>

  <url type="homepage">https://github.com/andrepg/do-it/</url>
  <url type="vcs-browser">https://github.com/andrepg/do-it/</url>
  <url type="bugtracker">https://github.com/andrepg/do-it/issues</url>
  <url type="donation">https://github.com/sponsors/andrepg</url>

  <launchable type="desktop-id">@APPLICATION_ID@.desktop</launchable>

  <content_rating type="oars-1.1"/>

  <branding>
    <color type="primary" scheme_preference="light">#f6f5f4</color>
    <color type="primary" scheme_preference="dark">#241f31</color>
  </branding>

  <screenshots>
    <screenshot type="default">
      <image>https://github.com/andrepg/do-it/blob/0.1.4/images/dark-pt-br.png?raw=true</image>
      <caption>Dark mode</caption>
    </screenshot>
    <screenshot>
      <image>https://github.com/andrepg/do-it/blob/0.1.4/images/light-pt-br.png?raw=true</image>
      <caption>Light mode</caption>
    </screenshot>
  </screenshots>

  <releases>
    <release version="2.0.0" timestamp="">
      <url type="details">https://github.com/andrepg/do-it/releases/tag/2.0.0</url>
      <description translate="no">
        <h2>A complete redesign of our app.</h2>

        <p>We've introduced a few thing meaningfull things. These changes aim to make task management better.</p>

        <ul>
          <li>New layout, with vertical sidebar and project groups</li>
          <li>Project management and automatic recognition with @ symbol</li>
          <li>Project filtering within sidebar navigation</li>
          <li>New sorting popover and settings</li>
        </ul>
      </description>
    </release>
    <release version="0.1.4" timestamp="1761495363990">
      <url type="details">https://github.com/andrepg/do-it/releases/tag/0.1.4</url>
      <description translate="no">
        <p>Sorting your tasks is now available. We've introduced a few things only.</p>

        <ul>
          <li>Tasks can be sorted by date, status or title</li>
          <li>This ordering setup is persisted, so you should not worry about loosing</li>
          <li>We've made touches on the empty list placeholder, making more Adwaita style</li>
          <li>Since we have order by dates, the task title now displays when your task was created</li>
        </ul>
      </description>
    </release>
  </releases>

</component>
