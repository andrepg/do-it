#!@GJS@ -m

import Gio from "gi://Gio";
import GLib from "gi://GLib";

import { bindtextdomain, textdomain } from "gettext"
import { exit, programArgs, programInvocationName } from "system";

bindtextdomain("@PACKAGE_NAME@", "@prefix@/share/locale");
textdomain("@PACKAGE_NAME@");

const APP_ID = "@APPLICATION_ID@";
const APP_NAME = "@APPLICATION_NAME@";
const APP_RES = "@APPLICATION_RES@";

imports.package.init({
  name: "@PACKAGE_NAME@",
  version: "@PACKAGE_VERSION@",
  prefix: "@prefix@",
  libdir: "@libdir@",
  datadir: "@datadir@",
});

bindtextdomain(APP_ID, "@prefix@/share/locale");
textdomain(APP_ID);

const { main } = await import("resource://@APPLICATION_RES@/src/entrypoint.js");

console.log(main);

exit(exitCode);
