#!/usr/bin/env bash
set -euo pipefail

# ===========================================================================
# update-pot-file — Gera o template POT e arquivos PO para traduções.
#
# Requer: meson, ninja e as dependências de build do projeto.
#
# Uso: scripts/update-pot-file
# @see https://rmnvgr.gitlab.io/gtk4-gjs-book/application/translation/
# @see https://docs.elementary.io/develop/writing-apps/our-first-app/translations
# ===========================================================================

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

BUILD_DIR="$PROJECT_ROOT/_build_pot"

echo "====> Gerando template POT..."
rm -rf "$BUILD_DIR" || true
meson setup "$BUILD_DIR"
meson compile -C "$BUILD_DIR" io.github.andrepg.Doit-pot

echo "====> Gerando arquivos PO para cada idioma..."
meson compile -C "$BUILD_DIR" io.github.andrepg.Doit-update-po

echo "====> Arquivos de tradução gerados com sucesso."
