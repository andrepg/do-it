#!/usr/bin/env bash
# ===========================================================================
# compile — Compiles the application via flatpak-builder.
#
# Usage: scripts/compile [manifest.json] [build-dir]
#   manifest.json  Flatpak manifest to use (default: io.github.andrepg.Doit.json)
#   build-dir     Build directory (default: _build)
#
# Flags:
#   --clean, -C   Full clean of cache before compiling
# ===========================================================================

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/lib-common.sh"

MANIFEST="io.github.andrepg.Doit.json"
BUILD_DIR="_build"
CLEAN=false

for arg in "$@"; do
    case "$arg" in
        --clean|-C) CLEAN=true ;;
        *.json) MANIFEST="$arg" ;;
        *) BUILD_DIR="$arg" ;;
    esac
done

log_section "Compiling manifest: $MANIFEST → $BUILD_DIR"

if $CLEAN; then
    log_section "Full cache cleaning..."
    clean_build_dir "$BUILD_DIR"
    clean_flatpak_builder_cache
else
    log_action "Cleaning old artifacts (keeping cache)..."
    clean_build_dir "$BUILD_DIR"
fi

log_section "Starting Flatpak build..."
run_flatpak_builder "$BUILD_DIR" "$MANIFEST"

log_section "Build completed: $BUILD_DIR"