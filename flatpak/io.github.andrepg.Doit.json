{
    "$schema": "../.vscode/schemas/flatpak-manifest.schema.json",
    "id": "io.github.andrepg.Doit",
    "tags": ["tasks", "todo", "task management"],
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.node24",
        "org.freedesktop.Sdk.Extension.typescript"
    ],
    "command": "io.github.andrepg.Doit",
    "finish-args": ["--device=dri", "--socket=wayland"],
    "build-options": {
        "append-path": "/usr/lib/sdk/typescript/bin:/usr/lib/sdk/node24/bin"
    },
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "node-deps",
            "buildsystem": "simple",
            "build-options": {
                "env": {
                    "npm_config_offline": "true",
                    "npm_config_cache": "/run/build/node-deps/npm-cache",
                    "YARN_CACHE_FOLDER": "/run/build/node-deps/yarn-cache"
                }
            },
            "build-commands": [
                "install -d /app/share/io.github.andrepg.Doit/node_modules",
                "yarn install --offline --frozen-lockfile --modules-folder=/app/share/io.github.andrepg.Doit/node_modules"
            ],
            "sources": [
                {
                    "type": "file",
                    "path": "../package.json"
                },
                {
                    "type": "file",
                    "path": "../yarn.lock"
                },
                {
                    "type": "file",
                    "path": "generated-sources.json",
                    "dest": "."
                }
            ]
        },
        {
            "name": "Doit",
            "buildsystem": "meson",
            "builddir": true,
            "config-opts": ["--libdir=lib", "-Ddevelopment=false"],
            "sources": [
                {
                    "type": "git",
                    "url": "https://github.com/andrepg/do-it/",
                    "branch": "v2",

                    "x-checker-data": {
                        "type": "git",
                        "github-repo": "andrepg/do-it"
                    }
                }
            ]
        }
    ]
}
