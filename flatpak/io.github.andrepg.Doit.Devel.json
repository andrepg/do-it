{
    "$schema": "../.vscode/schemas/flatpak-manifest.schema.json",
    "id": "io.github.andrepg.Doit.Devel",
    "tags": ["tasks", "todo", "task management"],
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.node24",
        "org.freedesktop.Sdk.Extension.typescript"
    ],
    "command": "io.github.andrepg.Doit.Devel",
    "finish-args": [
        "--device=dri",
        "--socket=wayland",
        "--filesystem=host",
        "--env=LC_ALL=pt_BR.UTF-8"
    ],
    "build-options": {
        "prepend-path": "/usr/lib/sdk/node24/bin:/usr/lib/sdk/typescript/bin",
        "prepend-ld-library-path": "/usr/lib/sdk/node24/lib:/usr/lib/sdk/typescript/lib",
        "build-args": ["--share=network"]
    },
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "Doit",
            "buildsystem": "simple",
            "build-options": {
                "append-path": "/usr/lib/sdk/node24/bin:/usr/lib/sdk/typescript/bin",
                "env": {
                    "YARN_CACHE_FOLDER": "/run/build/Doit/flatpak-node/yarn-mirror"
                }
            },
            "build-commands": [
                "yarn install --frozen-lockfile --ignore-scripts",
                "meson setup _flatpak_build --prefix=/app --libdir=lib -Ddevelopment=true",
                "meson compile -C _flatpak_build",
                "meson install -C _flatpak_build"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "../"
                }
            ]
        }
    ]
}
