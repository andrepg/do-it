{
    "$schema": "../.vscode/schemas/flatpak-manifest.schema.json",
    "id": "io.github.andrepg.Doit.Devel",
    "branch": "main",
    "command": "io.github.andrepg.Doit.Devel",
    "tags": ["tasks", "todo", "productivity"],
    "runtime": "org.gnome.Platform",
    "runtime-version": "50",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.node24",
        "org.freedesktop.Sdk.Extension.typescript"
    ],
    "finish-args": [
        "--device=dri",
        "--socket=wayland",
        "--filesystem=host",
        "--filesystem=home/.local/share/icons:ro",
        "--bind-mount=/usr/share/icons=/usr/share/icons"
    ],
    "build-options": {
        "prepend-path": "/usr/lib/sdk/node24/bin:/usr/lib/sdk/typescript/bin",
        "prepend-ld-library-path": "/usr/lib/sdk/node24/lib:/usr/lib/sdk/typescript/lib"
    },
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "Doit",
            "buildsystem": "simple",
            "build-options": {
                "append-path": "/usr/lib/sdk/node24/bin:/usr/lib/sdk/typescript/bin",
                "env": {
                    "YARN_CACHE_FOLDER": "/run/build/Doit/flatpak-node/yarn-mirror"
                }
            },
            "build-commands": [
                "meson setup --reconfigure _build --prefix=/app --libdir=lib -Ddevelopment=true",
                "meson compile -C _build",
                "meson install -C _build"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "../"
                }
            ]
        }
    ]
}
