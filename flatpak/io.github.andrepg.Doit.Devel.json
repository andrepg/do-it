{
    "$schema": "../.vscode/schemas/flatpak-manifest.schema.json",
    "id": "io.github.andrepg.Doit.Devel",
    "tags": [
        "tasks",
        "todo",
        "task management"
    ],
    "runtime": "org.gnome.Platform",
    "runtime-version": "49",
    "sdk": "org.gnome.Sdk",
    "sdk-extensions": [
        "org.freedesktop.Sdk.Extension.node24",
        "org.freedesktop.Sdk.Extension.typescript"
    ],
    "command": "io.github.andrepg.Doit.Devel",
    "finish-args": [
        "--device=dri",
        "--socket=wayland",
        "--env=LC_ALL=pt_BR.UTF-8"
    ],
    "build-options": {
        "prepend-path": "/usr/lib/sdk/node24/bin:/usr/lib/sdk/typescript/bin",
        "prepend-ld-library-path": "/usr/lib/sdk/node24/lib:/usr/lib/sdk/typescript/lib"
    },
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "Doit",
            "buildsystem": "meson",
            "builddir": true,
            "config-opts": [
                "-Ddevelopment=true",
                "--libdir=lib"
            ],
            "sources": [
                {
                    "type": "dir",
                    "path": "../"
                }
            ]
        }
    ]
}