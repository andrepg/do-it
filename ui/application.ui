<?xml version='1.0' encoding='UTF-8'?>
<!-- Created with Cambalache 0.96.3 -->
<interface>
  <!-- interface-name application.ui -->
  <requires lib="gtk" version="4.18"/>
  <requires lib="libadwaita" version="1.7"/>
  <requires lib="gio" version="2.0"/>
  <template class="DoItMainWindow" parent="AdwApplicationWindow">
    <property name="content">
      <object class="AdwNavigationSplitView">
        <property name="content">
          <object class="AdwNavigationPage">
            <property name="child">
              <object class="AdwToolbarView">
                <property name="bottom-bar-style">raised</property>
                <property name="content">
                  <object class="AdwToastOverlay">
                    <child>
                      <object class="GtkScrolledWindow">
                        <child>
                          <object class="GtkBox">
                            <property name="orientation">vertical</property>
                            <property name="spacing">24</property>
                            <property name="valign">start</property>
                            <child>
                              <object class="AdwClamp">
                                <property name="valign">start</property>
                                <child>
                                  <object class="AdwPreferencesGroup">
                                    <property name="header-suffix">
                                      <object class="AdwAvatar"/>
                                    </property>
                                    <property name="title">Nome do projeto</property>
                                    <property name="valign">start</property>
                                    
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwClamp">
                                <property name="valign">start</property>
                                <child>
                                  <object class="AdwPreferencesGroup">
                                    <property name="header-suffix">
                                      <object class="AdwAvatar"/>
                                    </property>
                                    <property name="title">Nome do projeto</property>
                                    <property name="valign">start</property>
                                    
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </child>
                  </object>
                </property>
                <property name="top-bar-style">raised</property>
                <child type="top">
                  <object class="AdwHeaderBar">
                    <property name="valign">start</property>
                    <child type="end">
                      <object class="GtkMenuButton">
                        <property name="focusable">True</property>
                        <property name="icon-name">open-menu-symbolic</property>
                        <property name="menu-model">
                          <menu id="primary_menu">
                            <section>
                              <item>
                                <attribute name="action">win.purge_deleted_tasks</attribute>
                                <attribute name="icon">user-trash-full-symbolic</attribute>
                                <attribute name="label" translatable="yes">Purge deleted tasks</attribute>
                              </item>
                            </section>
                            <section>
                              <attribute name="label">Backup</attribute>
                              <item>
                                <attribute name="action">win.export_database</attribute>
                                <attribute name="icon">document-save-symbolic</attribute>
                                <attribute name="label" translatable="yes">_Export Database</attribute>
                              </item>
                              <item>
                                <attribute name="action">win.import_database</attribute>
                                <attribute name="icon">document-send-symbolic</attribute>
                                <attribute name="label" translatable="yes">_Import Database</attribute>
                              </item>
                            </section>
                            <section>
                              <item>
                                <attribute name="action">win.show-help-overlay</attribute>
                                <attribute name="icon">keyboard-symbolic</attribute>
                                <attribute name="label" translatable="yes">_Keyboard Shortcuts</attribute>
                              </item>
                              <item>
                                <attribute name="action">app.about</attribute>
                                <attribute name="label" translatable="yes">_About Do It</attribute>
                              </item>
                            </section>
                          </menu>
                        </property>
                        <property name="primary">True</property>
                        <property name="tooltip-text" translatable="yes">Main Menu</property>
                      </object>
                    </child>
                  </object>
                </child>
                <child type="bottom">
                  <object class="GtkActionBar">
                    <property name="hexpand">True</property>
                    <property name="hexpand-set">True</property>
                    <property name="valign">end</property>
                    <child type="center">
                      <object class="GtkEntry" id="task_new_entry">
                        <property name="enable-emoji-completion">True</property>
                        <property name="hexpand">True</property>
                        <property name="placeholder-text" translatable="yes">What do you need to do?</property>
                        <property name="show-emoji-icon">True</property>
                        <property name="truncate-multiline">True</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </property>
            <property name="title">Do It</property>
          </object>
        </property>
        <property name="sidebar">
          <object class="AdwNavigationPage"/>
        </property>
      </object>
    </property>
  </template>
</interface>
